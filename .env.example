# Namecheap API — for `npm run dns` (enable API in Namecheap → Profile → Tools)
# Whitelist your public IP as NAMECHEAP_CLIENT_IP
# NAMECHEAP_API_USER=your_namecheap_username
# NAMECHEAP_API_KEY=your_api_key
# NAMECHEAP_USERNAME=your_namecheap_username
# NAMECHEAP_CLIENT_IP=your.public.ip.address
# NAMECHEAP_DOMAIN=spacesalvagers.com
# Your Pump.fun token mint address (from the coin URL)
VITE_PUMP_MINT=

# Optional — defaults to https://pump.fun/coin/<MINT>
# VITE_PUMP_URL=https://pump.fun/coin/YourMintHere

# Optional Solana RPC (defaults to public mainnet)
# VITE_SOLANA_RPC=https://api.mainnet-beta.solana.com

# Multiplayer relay — Fly: npm run mp-deploy · Render: Blueprint from render.yaml (free)
# CNAME mp.spacesalvagers.com → relay host, then: VITE_MP_SERVER=wss://mp.spacesalvagers.com npm run deploy
# VITE_MP_SERVER=wss://mp.spacesalvagers.com
